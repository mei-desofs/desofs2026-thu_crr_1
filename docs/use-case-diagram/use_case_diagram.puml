@startuml use_case_diagram
left to right direction
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #F9F9F9
  BorderColor #333
}

actor "Anonymous User" as Anonymous_User
actor "Authenticated User" as User
actor Customer
actor Carrier
actor Manager
actor "Invited User" as InvitedUser

Customer --|> User
Carrier --|> User
Manager --|> User
InvitedUser --|> Anonymous_User

rectangle "TechStore System" {

' Authentication
(Register Account) as UC_Register
(Log In) as UC_Login
(Log Out) as UC_Logout
(Request Password Reset) as UC_Reset

Anonymous_User --> UC_Register
Anonymous_User --> UC_Login
Anonymous_User --> UC_Reset

User --> UC_Logout

' Product Browsing
(View Products) as UC_ViewProducts
(Search Products) as UC_SearchProducts

UC_ViewProducts <.. UC_SearchProducts : <<extend>>

Anonymous_User --> UC_ViewProducts
User --> UC_ViewProducts

' Product Management
(Create Product) as UC_CreateProduct
(Update Product) as UC_UpdateProduct

Manager --> UC_CreateProduct
Manager --> UC_UpdateProduct

' Cart
(View Cart) as UC_ViewCart
(Add Product to Cart) as UC_AddCart
(Update Cart Item) as UC_UpdateCart
(Remove Product from Cart) as UC_RemoveCart

Customer --> UC_ViewCart
Customer --> UC_AddCart
Customer --> UC_UpdateCart
Customer --> UC_RemoveCart

' Orders
(Place Order) as UC_PlaceOrder
(View Order History) as UC_ViewOrders

Customer --> UC_PlaceOrder
Customer --> UC_ViewOrders

' Carrier
(View Assigned Orders) as UC_CarrierOrders
(Mark Order as Picked Up) as UC_Pickup

Carrier --> UC_CarrierOrders
Carrier --> UC_Pickup

' Invitations
(Invite User) as UC_Invite
(User Registration) as UC_UserRegistration

Manager --> UC_Invite
InvitedUser --> UC_UserRegistration

' System
(Create Backup) as UC_Backup

Manager --> UC_Backup

}

@enduml