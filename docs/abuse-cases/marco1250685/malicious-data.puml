@startuml Malicious_Product_Data_Injection

left to right direction

together{
actor Manager
}

together{
    (Create Product) as A1 #LightBlue
    (Submit product data) as A2 #LightBlue
    (Validate input server side) as A3 #LightBlue
    (Sanitize and encode output) as A4 #LightBlue
    (Apply size and format limits) as A5 #LightBlue
    (Log product creation events) as A6 #LightBlue
    (Safe rendering in UI) as A7 #LightBlue
}

together{
    (Stored XSS via product fields) as AT1
    (Corrupt product catalog data) as AT2
    (Injection into downstream systems) as AT3
    (Oversized payload DoS) as AT4
}

together{
actor Malicious_User #red
}

Manager -- A1

Malicious_User -up[#red]- AT1
Malicious_User -up[#red]- AT2
Malicious_User -up[#red]- AT3
Malicious_User -up[#red]- AT4

AT3 .right.> AT2 : <<Includes>>

AT1 -[#red,dashed]up--> A1 : threatens
AT2 -[#red,dashed]up--> A1 : threatens
AT3 -[#red,dashed]up--> A1 : threatens
AT4 -[#red,dashed]up--> A1 : threatens

A3 -[#green,dashed]-> AT1 : mitigates
A3 -[#green,dashed]-> AT2 : mitigates
A4 -[#green,dashed]-> AT1 : mitigates
A4 -[#green,dashed]-> AT3 : mitigates
A5 -[#green,dashed]-> AT4 : mitigates
A6 -[#green,dashed]-> AT2 : mitigates
A7 -[#green,dashed]-> AT1 : mitigates

A1 ..> A2 : <<Includes>>
A1 .> A3 : <<Includes>>
A1 .> A4 : <<Includes>>
A1 .> A5 : <<Includes>>
A1 .> A6 : <<Includes>>
A1 .> A7 : <<Includes>>

@enduml