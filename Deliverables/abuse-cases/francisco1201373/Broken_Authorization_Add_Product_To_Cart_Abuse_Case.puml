@startuml

left to right direction

together {
actor Customer
}

together {
    (Add Product To Cart Operation) as A1 #LightBlue
    (Submit Add Product request) as A2 #LightBlue
    (Validate customer cart context) as A3 #LightBlue

    (Validate customer access token) as A4 #LightBlue
    (Enforce customer-to-cart ownership check) as A5 #LightBlue
    (Bind token identity to cart ownership) as A6 #LightBlue
    (Log unauthorized add-to-cart attempts) as A7 #LightBlue
}

together {
(Ownership bypass in add-to-cart endpoint) as AT1
(Reuse captured token to access victim cart) as AT2
(Unauthorized add-product action executed) as AT3
}

together {
actor Malicious_User #red
}

Customer -- A1
A2 ..> A1 : <<Extend>>
A3 ..> A1 : <<Extend>>

A2 ..> A4 : <<Includes>>
A3 ..> A4 : <<Includes>>
A4 ..> A5 : <<Includes>>
A5 ..> A6 : <<Includes>>
A6 ..> A7 : <<Includes>>

Malicious_User -right[#red]- AT1
Malicious_User -right[#red]- AT2
Malicious_User -right[#red]- AT3

AT1 ..> AT2 : <<Includes>>
AT2 ..> AT3 : <<Includes>>

AT1 -[#red,dashed]left-> A4 : threatens

A4 -[#green,dashed]-> AT2 : mitigates
A5 -[#green,dashed]-> AT1 : mitigates
A6 -[#green,dashed]-> AT1 : mitigates
A7 -[#green,dashed]-> AT1 : mitigates

@enduml
