    {
      "name": "SR8 Encryption at rest and in transit",
      "item": [
        {
          "name": "Encryption in Transit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Correr contra o URL de produção: https://techstore.francecentral.cloudapp.azure.com",
                  "",
                  "pm.test(\"SR8 - Request was made over HTTPS\", () => {",
                  "    pm.expect(pm.request.url.protocol).to.equal(\"https\");",
                  "});",
                  "",
                  "pm.test(\"SR8 - Response received successfully over HTTPS\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"SR8 - HSTS header is present\", () => {",
                  "    pm.expect(pm.response.headers.get(\"Strict-Transport-Security\")).to.not.be.null;",
                  "});",
                  "",
                  "pm.test(\"SR8 - HSTS includes max-age\", () => {",
                  "    const hsts = pm.response.headers.get(\"Strict-Transport-Security\");",
                  "    pm.expect(hsts).to.include(\"max-age=\");",
                  "});",
                  "",
                  "pm.test(\"SR8 - HSTS includes includeSubDomains\", () => {",
                  "    const hsts = pm.response.headers.get(\"Strict-Transport-Security\");",
                  "    pm.expect(hsts).to.include(\"includeSubDomains\");",
                  "});",
                  "",
                  "pm.test(\"SR8 - Security headers present\", () => {",
                  "    pm.expect(pm.response.headers.get(\"X-Content-Type-Options\")).to.equal(\"nosniff\");",
                  "    pm.expect(pm.response.headers.get(\"X-Frame-Options\")).to.equal(\"DENY\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url-prod}}/actuator/health",
              "host": [
                "{{url-prod}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
