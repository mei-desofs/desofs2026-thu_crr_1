    {
      "name": "SR1 MFA",
      "item": [
        {
          "name": "Try Login When User Has MFA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"accessToken is null\", () => {",
                  "    pm.expect(json.accessToken).to.be.null;",
                  "});",
                  "",
                  "pm.test(\"refreshToken is null\", () => {",
                  "    pm.expect(json.refreshToken).to.be.null;",
                  "});",
                  "",
                  "pm.test(\"tokenType is null\", () => {",
                  "    pm.expect(json.tokenType).to.be.null;",
                  "});",
                  "",
                  "pm.test(\"expiresIn is null\", () => {",
                  "    pm.expect(json.expiresIn).to.be.null;",
                  "});",
                  "",
                  "pm.test(\"mfaRequired is true\", () => {",
                  "    pm.expect(json.mfaRequired).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"factorId is present\", () => {",
                  "    pm.expect(json.factorId).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"mfaToken is present\", () => {",
                  "    pm.expect(json.mfaToken).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "// Save for next steps",
                  "pm.collectionVariables.set(\"mfaToken\", json.mfaToken);",
                  "pm.collectionVariables.set(\"factorId\", json.factorId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"diogomartins2709@hotmail.com\",\n    \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/auth/login",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "MFA Challenge",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"challengeId is present\", () => {",
                  "    pm.expect(json.id).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"challengeId\", json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-MFA-Token",
                "value": "{{mfaToken}}",
                "type": "text"
