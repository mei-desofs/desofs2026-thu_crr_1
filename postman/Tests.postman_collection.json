                  "pm.test(\"Message is generic - does not mention user not found\", () => {",
                  "    pm.expect(json.message.toLowerCase()).to.not.include(\"not found\");",
                  "});",
                  "",
                  "pm.test(\"Message is generic - does not mention account exists\", () => {",
                  "    pm.expect(json.message.toLowerCase()).to.not.include(\"exist\");",
                  "});",
                  "",
                  "pm.test(\"Message is generic - does not mention invalid email\", () => {",
                  "    pm.expect(json.message.toLowerCase()).to.not.include(\"invalid email\");",
                  "});",
                  "",
                  "pm.test(\"Message is generic - does not mention invalid password\", () => {",
